{
  "name": "sydneyhillsmakan",
  "description": "HMG (Hills Makan Group) International website",
  "version": "4.2.0",
  "scripts": {
    "clean": "rm -rf node_modules .astro dist",
    "dev": "pnpm run build:search-index && pnpm run sync:pagefind:dev && astro dev",
    "geocode": "tsx src/utils/geocode.mts",
    "build": "pnpm run build:search-index",
    "build:search-index": "pnpm run geocode && astro build && pagefind --site dist",
    "sync:pagefind:dev": "rm -rf public/pagefind && cp -R dist/pagefind public/pagefind",
    "preview": "astro preview",
    "lint": "pnpm run lint:prettier && pnpm run lint:eslint",
    "lint:prettier": "prettier --write  \"src/**/*.{js,jsx,ts,tsx,md,astro}\"",
    "lint:eslint": "eslint --fix \"src/**/*.{js,ts,jsx,tsx,astro}\"",
    "refresh": "pnpm dlx @astrojs/upgrade; pnpm up -L",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/noto": "^1.2.7",
    "@iconify-json/ph": "^1.2.2",
    "@iconify-json/twemoji": "^1.2.5",
    "astro": "^6.4.8",
    "astro-icon": "^1.1.5",
    "astro-robots-txt": "^1.0.0",
    "astro-seo": "^1.1.0",
    "leaflet": "^1.9.4",
    "pagefind": "^1.5.2",
    "photoswipe": "^5.4.4",
    "schema-dts": "^2.0.0",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^8.0.2",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^26.0.0",
    "astro-eslint-parser": "^2.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-astro": "^2.0.0",
    "eslint-plugin-better-tailwindcss": "^4.6.0",
    "eslint-plugin-import-x": "^4.17.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-unicorn": "^68.0.0",
    "globals": "^17.7.0",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "pnpm": {
    "overrides": {
      "vite": "^7.3.2"
    }
  }
}
