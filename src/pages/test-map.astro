---
import { getCollection } from 'astro:content'
import BaseLayout from '../layouts/base.astro'
import PartnerMap from '../components/PartnerMap.astro'

const [samplePage] = await getCollection('pages', (p) => !p.data.draft)

if (!samplePage) {
  throw new Error('No published pages available to provide BaseLayout frontmatter in test-map.')
}
---

<BaseLayout frontmatter={samplePage.data}>
  <h1 class="mb-8 text-3xl font-bold dark:text-white">Partner Map Test</h1>
  <div class="w-full px-4 py-6 sm:px-6 sm:py-8 md:ml-64 md:w-[calc(100%-16rem)]">
    <div class="w-full max-w-full min-w-0 overflow-hidden rounded-lg">
      <PartnerMap />
    </div>
  </div>
</BaseLayout>
