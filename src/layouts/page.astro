---
import Base from './base.astro'
import PageHero from '../components/pagehero.astro'
import type { CollectionEntry } from 'astro:content'

export interface Props {
  frontmatter: CollectionEntry<'pages'>['data']
}

const { frontmatter } = Astro.props
---

<Base {frontmatter}>
  <main class="
    bg-white pt-8 pb-16 antialiased
    lg:pt-16 lg:pb-24
    dark:bg-gray-900
  ">
    <div class="mx-auto flex max-w-(--breakpoint-xl) justify-between px-4">
      <article
        class="
          format format-sm mx-auto w-full max-w-2xl format-blue
          sm:format-base
          lg:format-lg
          dark:format-invert
        "
      >
        <PageHero frontmatter={frontmatter} />
        <slot />
      </article>
    </div>
  </main>
</Base>
