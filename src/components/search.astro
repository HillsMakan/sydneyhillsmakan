<div
  id="search-widget"
  class="relative ml-2 w-40 sm:w-52 md:ml-4 md:w-72 lg:w-96 xl:w-136">
  <pagefind-searchbox
    id="search"
    placeholder="Search"
    debounce="150"
    show-sub-results
    hide-shortcut></pagefind-searchbox>
</div>

<style is:global>
  :root {
    --pagefind-ui-primary: #2563eb;
    --pagefind-ui-text: #111827;
    --pagefind-ui-background: #ffffff;
    --pagefind-ui-border: #d1d5db;
    --pagefind-ui-tag: #f3f4f6;
  }

  .dark {
    --pagefind-ui-primary: #3b82f6;
    --pagefind-ui-text: #f9fafb;
    --pagefind-ui-background: #1f2937;
    --pagefind-ui-border: #374151;
    --pagefind-ui-tag: #374151;
  }

  #search-widget .pf-searchbox-input {
    background-color: var(--pagefind-ui-background) !important;
    border-color: var(--pagefind-ui-border) !important;
    font-size: 0.875rem !important;
    border-radius: 0.375rem !important;
    padding: 0.5rem 0.75rem 0.5rem 2.25rem !important;
  }

  #search-widget .pf-searchbox-dropdown {
    position: absolute !important;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 50;
    background-color: var(--pagefind-ui-background);
    padding: 1rem;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    border: 1px solid var(--pagefind-ui-border);
    border-radius: 0.5rem;
    margin-top: 0.5rem;
    max-height: 60vh;
    overflow-y: auto;
  }
</style>
