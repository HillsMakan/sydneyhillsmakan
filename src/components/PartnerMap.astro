---
import { getCollection } from 'astro:content';

const allPartners = await getCollection('partner');
const mapPartners = allPartners
  .filter(p => p.data.coordinates)
  .map(p => ({
    id: p.id,
    title: p.data.title,
    description: p.data.description,
    coordinates: p.data.coordinates,
    categories: p.data.categories.map(c => c.id),
    cuisine: p.data.cuisine || [],
    region: p.data.region.id,
    link: `/partner/${p.id}/`
  }));

const allCategories = await getCollection('categories');
const activeCategoryIds = new Set(mapPartners.flatMap(p => p.categories));
const categories = allCategories
  .filter(c => activeCategoryIds.has(c.id))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const allRegions = await getCollection('region');
const activeRegionIds = new Set(mapPartners.map(p => p.region));
const regions = allRegions
  .filter(r => activeRegionIds.has(r.id))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const cuisines = [...new Set(mapPartners.flatMap(p => p.cuisine))].sort();
---

<div class="mb-6 grid grid-cols-1 md:grid-cols-3 gap-4">
  <div>
    <label for="filter-region" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Region</label>
    <select id="filter-region" class="w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 dark:bg-gray-800 dark:border-gray-700 dark:text-white sm:text-sm">
      <option value="">All Regions</option>
      {regions.map(r => <option value={r.id}>{r.data.title}</option>)}
    </select>
  </div>
  <div>
    <label for="filter-category" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Category</label>
    <select id="filter-category" class="w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 dark:bg-gray-800 dark:border-gray-700 dark:text-white sm:text-sm">
      <option value="">All Categories</option>
      {categories.map(c => <option value={c.id}>{c.data.title}</option>)}
    </select>
  </div>
  <div>
    <label for="filter-cuisine" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Cuisine</label>
    <select id="filter-cuisine" class="w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 dark:bg-gray-800 dark:border-gray-700 dark:text-white sm:text-sm">
      <option value="">All Cuisines</option>
      {cuisines.map(c => <option value={c}>{c}</option>)}
    </select>
  </div>
</div>

<div id="partner-map" 
     class="h-[600px] w-full rounded-lg shadow-md z-0"
     data-partners={JSON.stringify(mapPartners)}>
</div>

<style>
  /* Import Leaflet CSS in the style block or in global.css */
  @import "leaflet/dist/leaflet.css";
</style>

<script>
  import L from 'leaflet';
  import icon from 'leaflet/dist/images/marker-icon.png';
  import iconRetina from 'leaflet/dist/images/marker-icon-2x.png';
  import iconShadow from 'leaflet/dist/images/marker-shadow.png';

  // Fix Leaflet default icon paths for Vite
  let DefaultIcon = L.icon({
    iconUrl: icon,
    iconRetinaUrl: iconRetina,
    shadowUrl: iconShadow,
    iconSize: [25, 41],
    iconAnchor: [12, 41],
    popupAnchor: [1, -34],
    shadowSize: [41, 41]
  });
  L.Marker.prototype.options.icon = DefaultIcon;

  const mapElement = document.getElementById('partner-map');
  if (mapElement) {
    const partners = JSON.parse(mapElement.getAttribute('data-partners') || '[]');
    console.log(`Loaded ${partners.length} partners for the map`);

    const map = L.map('partner-map').setView([-33.8688, 151.2093], 12);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      maxZoom: 19,
      attribution: '© OpenStreetMap contributors'
    }).addTo(map);

    const markerGroup = L.layerGroup().addTo(map);

    partners.forEach(partner => {
      if (partner.coordinates) {
        const marker = L.marker([partner.coordinates.lat, partner.coordinates.lng])
          .bindPopup(`
            <div class="p-1">
              <h3 class="font-bold text-base mb-1">${partner.title}</h3>
              <p class="text-xs text-gray-600 mb-2">${partner.description}</p>
              <a href="${partner.link}" class="text-blue-600 hover:underline text-xs font-semibold">View Details →</a>
            </div>
          `);
        markerGroup.addLayer(marker);
      }
    });

    if (partners.length > 0) {
      const bounds = L.latLngBounds(partners.map(p => [p.coordinates.lat, p.coordinates.lng]));
      map.fitBounds(bounds, { padding: [50, 50] });
    }

    console.log('Map initialized with markers');
  }
</script>
