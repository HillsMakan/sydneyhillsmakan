---
import { getCollection } from 'astro:content'

const allPartners = await getCollection('partner', (p) => !p.data.draft)
const allRegions = await getCollection('region', (r) => !r.data.draft)

// Create a lookup map for regions to support hierarchical filtering and title lookup
const regionMap = new Map(allRegions.map((r) => [r.id, r]))

const mapPartners = allPartners
  .filter((p) => p.data.coordinates)
  .map((p) => {
    const regionId = p.data.region.id
    const region = regionMap.get(regionId)
    return {
      id: p.id,
      title: p.data.title,
      description: p.data.description,
      coordinates: p.data.coordinates,
      categories: p.data.categories.map((c) => c.id),
      cuisine: p.data.cuisine || [],
      region: regionId,
      regionName: region?.data.title || regionId,
      country: region?.data.country?.id || null,
      link: `/partner/${p.id}/`
    }
  })

const activeCategoryIds = new Set(mapPartners.flatMap((p) => p.categories))
const allCategories = await getCollection('categories')
const categories = allCategories
  .filter((c) => activeCategoryIds.has(c.id))
  .sort((a, b) => a.data.title.localeCompare(b.data.title))

const activeRegionIds = new Set(mapPartners.map((p) => p.region))
// Also include countries that have active regions
const activeCountryIds = new Set(
  mapPartners.filter((p) => p.country).map((p) => p.country as string)
)

const regions = allRegions
  .filter((r) => activeRegionIds.has(r.id) || activeCountryIds.has(r.id))
  .sort((a, b) => a.data.title.localeCompare(b.data.title))

const cuisines = [...new Set(mapPartners.flatMap((p) => p.cuisine))].sort()
---

<div class="mb-6 grid grid-cols-1 items-end gap-4 sm:grid-cols-2 lg:grid-cols-4">
  <div>
    <label
      for="filter-region"
      class="mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300"
      >Region / Country</label
    >
    <select
      id="filter-region"
      class="w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm dark:border-gray-700 dark:bg-gray-800 dark:text-white"
    >
      <option value="">All Regions</option>
      {regions.map((r) => <option value={r.id}>{r.data.title}</option>)}
    </select>
  </div>
  <div>
    <label
      for="filter-category"
      class="mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300">Category</label
    >
    <select
      id="filter-category"
      class="w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm dark:border-gray-700 dark:bg-gray-800 dark:text-white"
    >
      <option value="">All Categories</option>
      {categories.map((c) => <option value={c.id}>{c.data.title}</option>)}
    </select>
  </div>
  <div>
    <label
      for="filter-cuisine"
      class="mb-1 block text-sm font-medium text-gray-700 dark:text-gray-300">Cuisine</label
    >
    <select
      id="filter-cuisine"
      class="w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm dark:border-gray-700 dark:bg-gray-800 dark:text-white"
    >
      <option value="">All Cuisines</option>
      {cuisines.map((c) => <option value={c}>{c}</option>)}
    </select>
  </div>
  <div>
    <button
      id="reset-map"
      class="w-full rounded-md bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-blue-700"
    >
      Reset Map
    </button>
  </div>
</div>

<div
  id="partner-map"
  class="z-0 h-[400px] w-full rounded-lg shadow-md md:h-[600px]"
  data-partners={JSON.stringify(mapPartners)}
>
</div>

<style>
  /* Ensure Leaflet popups are readable in dark mode */
  :global(.leaflet-popup-content-wrapper) {
    background-color: white !important;
    color: #1a202c !important;
  }
  :global(.leaflet-popup-tip) {
    background-color: white !important;
  }
</style>

<script>
  import L from 'leaflet'
  import iconUrl from 'leaflet/dist/images/marker-icon.png?url'
  import iconRetinaUrl from 'leaflet/dist/images/marker-icon-2x.png?url'
  import shadowUrl from 'leaflet/dist/images/marker-shadow.png?url'

  // Fix Leaflet default icon paths for Vite
  const DefaultIcon = L.icon({
    iconUrl: typeof iconUrl === 'string' ? iconUrl : (iconUrl as any).src,
    iconRetinaUrl: typeof iconRetinaUrl === 'string' ? iconRetinaUrl : (iconRetinaUrl as any).src,
    shadowUrl: typeof shadowUrl === 'string' ? shadowUrl : (shadowUrl as any).src,
    iconSize: [25, 41],
    iconAnchor: [12, 41],
    popupAnchor: [1, -34],
    shadowSize: [41, 41]
  })
  L.Marker.prototype.options.icon = DefaultIcon

  const mapElement = document.querySelector('#partner-map')
  if (mapElement) {
    const partners = JSON.parse(mapElement.dataset.partners || '[]')
    console.log(`Loaded ${partners.length} partners for the map`)

    const map = L.map('partner-map', {
      scrollWheelZoom: false
    }).setView([-33.8688, 151.2093], 12)

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      maxZoom: 19,
      attribution:
        '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
    }).addTo(map)

    const markerGroup = L.layerGroup().addTo(map)

    const regionFilter = document.querySelector('#filter-region') as HTMLSelectElement
    const categoryFilter = document.querySelector('#filter-category') as HTMLSelectElement
    const cuisineFilter = document.querySelector('#filter-cuisine') as HTMLSelectElement

    // Helper to jitter overlapping coordinates
    const jitter = () => (Math.random() - 0.5) * 0.005

    function renderMarkers(filteredPartners: any[]) {
      markerGroup.clearLayers()
      const boundsArr: L.LatLngExpression[] = []
      const seenCoords = new Set<string>()

      for (const partner of filteredPartners) {
        if (partner.coordinates) {
          let lat = partner.coordinates.lat
          let lng = partner.coordinates.lng

          // Jitter if identical to another marker to avoid overlapping
          const coordKey = `${lat.toFixed(4)},${lng.toFixed(4)}`
          if (seenCoords.has(coordKey)) {
            lat += jitter()
            lng += jitter()
          }
          seenCoords.add(`${lat.toFixed(4)},${lng.toFixed(4)}`)

          const marker = L.marker([lat, lng]).bindPopup(
            `
            <div class="p-1 min-w-[180px]">
              <h3 class="font-bold text-base mb-1 text-gray-900">${partner.title}</h3>
              <p class="text-[10px] font-bold text-blue-600 uppercase tracking-wider mb-1">${partner.regionName}</p>
              <p class="text-xs text-gray-600 mb-2 leading-tight">${partner.description}</p>
              <a href="${partner.link}" class="inline-block bg-blue-50 text-blue-700 hover:bg-blue-100 px-2 py-1 rounded text-[10px] font-bold uppercase transition-colors">View Details →</a>
            </div>
          `,
            {
              maxWidth: 250
            }
          )
          markerGroup.addLayer(marker)
          boundsArr.push([lat, lng])
        }
      }

      if (boundsArr.length > 0) {
        const bounds = L.latLngBounds(boundsArr)
        map.fitBounds(bounds, { padding: [50, 50], maxZoom: 15 })
      }
    }

    function updateMarkers() {
      const selectedRegion = regionFilter.value
      const selectedCategory = categoryFilter.value
      const selectedCuisine = cuisineFilter.value

      const filteredPartners = partners.filter((p: any) => {
        const matchesRegion =
          !selectedRegion || p.region === selectedRegion || p.country === selectedRegion
        const matchesCategory = !selectedCategory || p.categories.includes(selectedCategory)
        const matchesCuisine = !selectedCuisine || p.cuisine.includes(selectedCuisine)
        return matchesRegion && matchesCategory && matchesCuisine
      })

      console.log(
        `Filtering: region=${selectedRegion}, category=${selectedCategory}, cuisine=${selectedCuisine} -> Found ${filteredPartners.length} matches`
      )
      renderMarkers(filteredPartners)
    }

    // Initial render
    renderMarkers(partners)

    // Force Leaflet to recalculate container size
    setTimeout(() => {
      map.invalidateSize()
    }, 200)
    for (const el of [regionFilter, categoryFilter, cuisineFilter]) {
      el?.addEventListener('change', updateMarkers)
    }

    const resetBtn = document.querySelector('#reset-map')
    resetBtn?.addEventListener('click', () => {
      regionFilter.value = ''
      categoryFilter.value = ''
      cuisineFilter.value = ''
      updateMarkers()
    })

    console.log('Map initialized with markers and filtering')
  }
</script>
